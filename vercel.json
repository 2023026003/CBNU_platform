{
  "crons": [
    {
      "path": "/api/cron/expire-matches",
      "schedule": "0 * * * *"
    }
  ],
  "functions": {
    "app/api/claude/**": {
      "maxDuration": 30
    },
    "app/api/cron/**": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
